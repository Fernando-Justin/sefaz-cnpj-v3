    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@testing-library/react": "^14.2.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "postcss": "^8.4.35",
    "ts-jest": "^29.1.2",
