{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "src/index.ts",
    "src/api/**/*",
    "src/interfaces/**/*"
  ],
  "exclude": ["node_modules", "dist", "src/components", "src/pages", "src/App.tsx", "src/main.tsx"]
}
