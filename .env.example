# Variáveis de Ambiente — Consulta CNPJ SEFAZ
# Copie este arquivo para .env e preencha os valores

# Porta do servidor da API Express
PORT=3000

# Ambiente de execução
NODE_ENV=development

# Endpoint WSDL da SEFAZ para a UF de SP
SEFAZ_WSDL_URL_SP=https://www.sefazvirtual.fazenda.gov.br/CadConsultaCadastro4/CadConsultaCadastro4.asmx?wsdl

# Caminho relativo (a partir da raiz do projeto) para o arquivo do Certificado Digital A1
CERT_PATH=certs/certificado.pfx

# Senha do Certificado Digital A1
CERT_PASS=suasenhadeexemplo

# Timeout máximo (em ms) para chamadas ao WebService da SEFAZ (SRD §6)
SOAP_TIMEOUT_MS=15000
